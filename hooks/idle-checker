#!/usr/bin/env bash
# TeammateIdle hook for oh-my-beom plugin
# 팀메이트 유휴 시 계획 파일의 미완료 항목을 확인하고 추가 작업을 지시한다.
# exit 0: 유휴 허용, exit 2: 유휴 차단 + stderr로 다음 작업 지시

set -euo pipefail

INPUT=$(cat /dev/stdin 2>/dev/null || echo '{}')
CWD=$(echo "$INPUT" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    print(data.get('cwd', '.'))
except:
    print('.')
" 2>/dev/null || echo ".")

# config.json에서 verification 설정 확인
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(dirname "$0")/..}"
CONFIG_FILE="${PLUGIN_ROOT}/config/config.json"

VERIFICATION_ENABLED=$(python3 -c "
import json
try:
    with open('${CONFIG_FILE}') as f:
        config = json.load(f)
    print('true' if config.get('verification', {}).get('enabled', True) else 'false')
except:
    print('true')
" 2>/dev/null || echo "true")

if [ "$VERIFICATION_ENABLED" = "false" ]; then
  exit 0
fi

# docs/plan/ 에서 IN_PROGRESS 계획 파일 탐색 + 미완료 TODO 수집
RESULT=$(python3 << 'PYEOF'
import glob, re, sys, os

cwd = sys.argv[1] if len(sys.argv) > 1 else "."
plan_dir = os.path.join(cwd, "docs", "plan")

if not os.path.isdir(plan_dir):
    print("IDLE_OK")
    sys.exit(0)

plans = glob.glob(os.path.join(plan_dir, "*-plan.md"))
remaining_todos = []
active_plan = None

for plan in plans:
    try:
        with open(plan) as f:
            content = f.read()
        if not re.search(r'상태:\s*IN_PROGRESS', content):
            continue
        active_plan = plan

        # 미완료 TODO 수집
        current_step = "Unknown"
        for line in content.split("\n"):
            step_match = re.match(r'### Step \d+:\s*(.+)', line)
            if step_match:
                current_step = step_match.group(1).strip()
            todo_match = re.match(r'- \[ \] \[(TODO-[\d.]+)\]\s*(.+)', line)
            if todo_match:
                todo_id = todo_match.group(1)
                todo_desc = todo_match.group(2).strip()
                remaining_todos.append(f"- [{todo_id}] {todo_desc} (Step: {current_step})")
        break
    except:
        continue

if not remaining_todos:
    print("IDLE_OK")
else:
    output = ["[REMAINING WORK] 계획에 미완료 항목이 있습니다.", "", "다음 작업:"]
    output.extend(remaining_todos[:5])  # 최대 5개만 표시
    if len(remaining_todos) > 5:
        output.append(f"  ... 외 {len(remaining_todos) - 5}개")
    if active_plan:
        output.append(f"\n계획 파일: {active_plan}")
    output.append("\n이 항목들을 계속 진행하세요.")
    print("\n".join(output))
PYEOF
"$CWD" 2>/dev/null || echo "IDLE_OK")

if [ "$RESULT" = "IDLE_OK" ]; then
  exit 0
else
  echo "$RESULT" >&2
  exit 2
fi
