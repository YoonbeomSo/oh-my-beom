#!/usr/bin/env bash
# PostToolUse hook for Bash
# Step 2: 실패 자동 학습 — 에러 패턴 기록 + 반복 에러 시 이전 해결 방법 주입
#
# Exit codes: 0=통과 (항상)

set -uo pipefail

INPUT=$(cat /dev/stdin 2>/dev/null || echo '{}')
CWD="${CLAUDE_CWD:-$(pwd)}"
ERROR_LOG="${CWD}/.dev/error-log.md"

# 성공한 명령은 무시
RESULT=$(echo "$INPUT" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    result = data.get('tool_result', data.get('result', {}))
    # exit_code가 0이 아닌 경우 또는 stderr에 에러가 있는 경우
    stdout = str(result.get('stdout', ''))
    stderr = str(result.get('stderr', ''))
    exit_code = result.get('exit_code', result.get('exitCode', 0))

    if exit_code == 0 and not stderr:
        print('SUCCESS')
    else:
        # 명령어 추출
        tool_input = data.get('tool_input', {})
        command = tool_input.get('command', 'unknown')

        # 에러 시그니처 생성 (첫 줄 기반)
        error_msg = stderr.strip().split('\n')[0] if stderr.strip() else stdout.strip().split('\n')[0]
        # 80자 제한
        error_msg = error_msg[:80]

        print(f'ERROR|{command[:100]}|{error_msg}|{exit_code}')
except Exception as e:
    print('SUCCESS')
" 2>/dev/null || echo "SUCCESS")

if [ "$RESULT" = "SUCCESS" ]; then
  exit 0
fi

# 에러 파싱
IFS='|' read -r _ COMMAND ERROR_MSG EXIT_CODE <<< "$RESULT"

# .dev 디렉토리 확인
if [ ! -d "${CWD}/.dev" ]; then
  # .dev가 없으면 /beom 세션이 아님 → 기록하지 않음
  exit 0
fi

# 에러 로그 초기화 (없으면)
if [ ! -f "$ERROR_LOG" ]; then
  cat > "$ERROR_LOG" << 'HEADER'
# Error Log

자동 기록된 에러 패턴. 반복 에러 감지 시 이전 해결 방법을 참고합니다.

HEADER
fi

# 중복 에러 감지 (동일 에러 메시지가 이미 기록되어 있는지)
ESCAPED_MSG=$(echo "$ERROR_MSG" | sed 's/[[\.*^$()+?{|]/\\&/g')
DUPLICATE_COUNT=$(grep -c "$ESCAPED_MSG" "$ERROR_LOG" 2>/dev/null || echo "0")

# 에러 기록
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
cat >> "$ERROR_LOG" << ENTRY

## [$TIMESTAMP] exit=$EXIT_CODE
- 명령: \`${COMMAND}\`
- 에러: ${ERROR_MSG}
ENTRY

# 반복 에러 시 이전 해결 방법 주입
if [ "$DUPLICATE_COUNT" -gt 0 ]; then
  # JSON-safe escape
  SAFE_MSG=$(echo "$ERROR_MSG" | python3 -c "
import sys
s = sys.stdin.read().strip()
s = s.replace('\\\\', '\\\\\\\\').replace('\"', '\\\\\"').replace('\n', '\\\\n')
print(s)
" 2>/dev/null || echo "$ERROR_MSG")

  CONTEXT="[ERROR LEARNER] 이 에러가 ${DUPLICATE_COUNT}회 반복되고 있습니다: ${SAFE_MSG}\\n\\n동일한 접근을 반복하지 마세요. 근본 원인을 먼저 분석하세요.\\n- 에러 로그: .dev/error-log.md\\n- 규칙 참고: rules/behavior.md §6 실패 대응"

  printf '{"hookSpecificOutput": {"hookEventName": "PostToolUse", "additionalContext": "%s"}}' "$CONTEXT"
else
  echo '{"continue": true}'
fi

exit 0
