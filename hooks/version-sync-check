#!/usr/bin/env bash
# PreToolUse version-sync-check hook
# git commit 실행 전, 플러그인 메타 파일 3개의 버전이 일치하는지 확인.
#
# 검사 대상:
#   - package.json: .version
#   - .claude-plugin/plugin.json: .version
#   - .claude-plugin/marketplace.json: .plugins[name=oh-my-beom].version
#
# 건너뛰기 조건:
#   - git commit이 아닌 경우
#   - --amend 커밋
#   - 위 3개 파일 중 하나라도 없는 경우 (이 hook이 적용되지 않는 프로젝트)

set -uo pipefail

INPUT=$(cat /dev/stdin 2>/dev/null || echo '{}')

FULL_CMD=$(echo "$INPUT" | python3 -c "
import json, sys
try:
    data = json.load(sys.stdin)
    print(data.get('tool_input', {}).get('command', ''))
except: print('')
" 2>/dev/null || echo "")

pass() { echo '{"continue": true}'; exit 0; }

# git commit이 아니면 통과
if ! echo "$FULL_CMD" | grep -qE '(^|[;&|]\s*)git\s+commit(\s|$)' 2>/dev/null; then
  pass
fi

# --amend는 기존 커밋 수정이라 건너뜀
if echo "$FULL_CMD" | grep -qE -- '--amend' 2>/dev/null; then
  pass
fi

# 프로젝트 루트
ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
[ -z "$ROOT" ] && pass

PKG="$ROOT/package.json"
PLUGIN="$ROOT/.claude-plugin/plugin.json"
MARKET="$ROOT/.claude-plugin/marketplace.json"

# 3개 파일 모두 있을 때만 검증
[ -f "$PKG" ] || pass
[ -f "$PLUGIN" ] || pass
[ -f "$MARKET" ] || pass

# oh-my-beom 플러그인 자체 개발 시에만 발동 (다른 플러그인 프로젝트는 통과)
PLUGIN_NAME=$(python3 -c "import json; print(json.load(open('$PLUGIN')).get('name',''))" 2>/dev/null || echo "")
[ "$PLUGIN_NAME" = "oh-my-beom" ] || pass

deny() {
  local reason="$1"
  reason=$(printf '%s' "$reason" | python3 -c "import json,sys; print(json.dumps(sys.stdin.read()))")
  cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "PreToolUse",
    "permissionDecision": "deny",
    "permissionDecisionReason": ${reason}
  }
}
EOF
  exit 0
}

# 버전 추출
V_PKG=$(python3 -c "import json; print(json.load(open('$PKG')).get('version','MISSING'))" 2>/dev/null || echo "ERROR")
V_PLUGIN=$(python3 -c "import json; print(json.load(open('$PLUGIN')).get('version','MISSING'))" 2>/dev/null || echo "ERROR")
V_MARKET=$(python3 -c "
import json
data = json.load(open('$MARKET'))
plugins = data.get('plugins', [])
# 이 플러그인의 source가 './'인 항목 (또는 첫 번째)을 찾아 버전 반환
target = next((p for p in plugins if p.get('source') == './'), plugins[0] if plugins else None)
print(target.get('version', 'MISSING') if target else 'MISSING')
" 2>/dev/null || echo "ERROR")

# 파싱 실패 시 통과 (다른 종류 프로젝트일 수 있음)
case "$V_PKG$V_PLUGIN$V_MARKET" in
  *ERROR*) pass ;;
esac

# 3개 모두 동일하면 통과
if [ "$V_PKG" = "$V_PLUGIN" ] && [ "$V_PKG" = "$V_MARKET" ]; then
  pass
fi

# 불일치 — 커밋 차단
deny "플러그인 버전 불일치 — 커밋 전 동기화 필요. | package.json=${V_PKG} | plugin.json=${V_PLUGIN} | marketplace.json=${V_MARKET} | /version-bump 스킬로 일괄 갱신하거나, 직접 3개 파일을 같은 값으로 맞추세요."
