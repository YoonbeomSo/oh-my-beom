#!/usr/bin/env bash
# SessionStart hook for oh-my-beom plugin
# Detects active (IN_PROGRESS) plans and injects context so the session
# knows about ongoing work immediately.

set -euo pipefail

CWD="${CLAUDE_CWD:-$(pwd)}"
PLAN_DIR="${CWD}/docs/plan"

# Helper: output workflow guide context
print_workflow_guide() {
  local GUIDE="[SESSION START - WORKFLOW GUIDE]\\n\\n어떤 작업을 하시겠습니까? 상황에 맞는 시작점을 추천합니다:\\n\\n| 상황 | 명령어 | 설명 |\\n|------|--------|------|\\n| 간단한 버그 수정 | /beom [설명] | Light 팀 (3명) 추천 |\\n| 신규 기능 개발 | /beom [설명] | Full 팀 (5명) 추천 |\\n| 긴급 핫픽스 | /beom --hotfix [설명] | coder 1명 즉시 수정 |\\n| 코드 파악이 먼저 | /research → /beom | 조사 후 개발 |\\n| 정책 분석이 먼저 | /lens → /beom | 정책 분석 후 개발 |\\n\\n> /beom이 유일한 개발 진입점입니다. /lens, /research는 사전 분석이 필요할 때 먼저 실행하세요."
  printf '{"hookSpecificOutput": {"hookEventName": "SessionStart", "additionalContext": "%s"}}' "$GUIDE"
}

# No plan directory → show workflow guide
if [ ! -d "$PLAN_DIR" ]; then
  print_workflow_guide
  exit 0
fi

# Find IN_PROGRESS plans and collect summary
RESULT=$(python3 << 'PYEOF'
import glob, re, sys, os

plan_dir = sys.argv[1] if len(sys.argv) > 1 else "docs/plan"
plans = glob.glob(os.path.join(plan_dir, "*-plan.md"))

active_plans = []

for plan in plans:
    try:
        with open(plan) as f:
            content = f.read()
        if not re.search(r'상태:\s*IN_PROGRESS', content):
            continue

        filename = os.path.basename(plan)
        # Extract title from first # heading
        title_match = re.search(r'^#\s+(.+)', content, re.MULTILINE)
        title = title_match.group(1).strip() if title_match else filename

        # Count TODOs
        total = len(re.findall(r'- \[[ x]\] \[TODO-', content))
        done = len(re.findall(r'- \[x\] \[TODO-', content))
        remaining = total - done

        active_plans.append({
            "file": plan,
            "title": title,
            "total": total,
            "done": done,
            "remaining": remaining,
        })
    except:
        continue

if not active_plans:
    print("NONE")
    sys.exit(0)

lines = ["[ACTIVE PLAN DETECTED]", ""]
for p in active_plans:
    progress = f"{p['done']}/{p['total']}" if p['total'] > 0 else "no TODOs"
    lines.append(f"- {p['title']} ({progress} done, {p['remaining']} remaining)")
    lines.append(f"  file: {p['file']}")
lines.append("")
lines.append("Continue from where the previous session left off.")
print("\n".join(lines))
PYEOF
"$PLAN_DIR" 2>/dev/null || echo "NONE")

if [ "$RESULT" = "NONE" ]; then
  print_workflow_guide
  exit 0
fi

# Escape for JSON
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

CONTEXT=$(escape_for_json "$RESULT")

printf '{"hookSpecificOutput": {"hookEventName": "SessionStart", "additionalContext": "%s"}}' "$CONTEXT"
exit 0
