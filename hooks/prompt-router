#!/usr/bin/env bash
# UserPromptSubmit hook for oh-my-beom plugin
# Routes user prompts to appropriate skills based on keyword detection

set -euo pipefail

# Read JSON input from stdin
INPUT=$(cat /dev/stdin 2>/dev/null || echo '{}')

# Extract prompt field using python3 (always available on macOS)
PROMPT=$(echo "$INPUT" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    print(data.get('prompt', data.get('content', '')))
except:
    print('')
" 2>/dev/null || echo "")

# Exit early if no prompt
if [ -z "$PROMPT" ]; then
  echo '{"continue": true, "suppressOutput": true}'
  exit 0
fi

# Escape string for JSON embedding using bash parameter substitution
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# Convert prompt to lowercase for case-insensitive matching
PROMPT_LOWER=$(echo "$PROMPT" | python3 -c "import sys; print(sys.stdin.read().lower())" 2>/dev/null || echo "$PROMPT")

# Keyword matching (Korean + English)
# NOTE: "beom" must be checked FIRST to avoid "beom 개발해" matching "dev"
MATCHED_SKILL=""

if echo "$PROMPT_LOWER" | python3 -c "
import sys, re
text = sys.stdin.read()
if re.search(r'^beom\b', text):
    sys.exit(0)
sys.exit(1)
" 2>/dev/null; then
  MATCHED_SKILL="beom"
elif echo "$PROMPT_LOWER" | python3 -c "
import sys, re
text = sys.stdin.read()
if re.search(r'정책|비즈니스|lens|영향도', text):
    sys.exit(0)
sys.exit(1)
" 2>/dev/null; then
  MATCHED_SKILL="lens"
elif echo "$PROMPT_LOWER" | python3 -c "
import sys, re
text = sys.stdin.read()
if re.search(r'분석해|조사해|research|리서치', text):
    sys.exit(0)
sys.exit(1)
" 2>/dev/null; then
  MATCHED_SKILL="research"
elif echo "$PROMPT_LOWER" | python3 -c "
import sys, re
text = sys.stdin.read()
if re.search(r'끝까지|멈추지마|완료할때까지|persist', text):
    sys.exit(0)
sys.exit(1)
" 2>/dev/null; then
  MATCHED_SKILL="persist"
elif echo "$PROMPT_LOWER" | python3 -c "
import sys, re
text = sys.stdin.read()
if re.search(r'개발해|구현해|만들어줘', text):
    sys.exit(0)
sys.exit(1)
" 2>/dev/null; then
  MATCHED_SKILL="beom"
fi

# Output result
if [ -z "$MATCHED_SKILL" ]; then
  echo '{"continue": true, "suppressOutput": true}'
else
  PROMPT_ESCAPED=$(escape_for_json "$PROMPT")
  CONTEXT="[KEYWORD DETECTED: ${MATCHED_SKILL}]\n\nYou MUST invoke the skill using the Skill tool:\n\nSkill: oh-my-beom:${MATCHED_SKILL}\n\nUser request:\n${PROMPT_ESCAPED}\n\nIMPORTANT: Invoke the skill IMMEDIATELY before any other action."
  CONTEXT_ESCAPED=$(escape_for_json "$CONTEXT")
  printf '{"continue": true, "hookSpecificOutput": {"hookEventName": "UserPromptSubmit", "additionalContext": "%s"}}' "$CONTEXT_ESCAPED"
fi

exit 0
