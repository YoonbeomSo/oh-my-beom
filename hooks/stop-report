#!/usr/bin/env bash
# Stop hook for oh-my-beom plugin
# /dev 세션 종료 시 결과 보고서가 아직 생성되지 않았으면
# Claude를 멈추지 않고 /report 스킬 실행을 지시한다.

set -euo pipefail

INPUT=$(cat)
CWD="${CLAUDE_CWD:-$(pwd)}"
STATE_FILE="${CWD}/.dev/state.md"
REPORT_FILE="${CWD}/.dev/report.md"

# .dev/state.md가 없으면 /dev 세션이 아님 → 정상 종료
if [ ! -f "$STATE_FILE" ]; then
  exit 0
fi

# 보고서가 이미 존재하면 → 정상 종료
if [ -f "$REPORT_FILE" ]; then
  exit 0
fi

# state.md에서 status 확인 (completed 또는 in_progress 후반부만)
STATUS=$(grep -oP '(?<=status:\s).*' "$STATE_FILE" 2>/dev/null || echo "unknown")

# setup 단계면 아직 의미있는 산출물 없음 → 정상 종료
PHASE=$(grep -oP '(?<=phase:\s).*' "$STATE_FILE" 2>/dev/null || echo "unknown")
if [ "$PHASE" = "setup" ]; then
  exit 0
fi

# 보고서 생성 지시
printf '{"decision":"block","reason":"/dev 세션의 결과 보고서가 아직 생성되지 않았습니다. /report 스킬을 호출하여 .dev/report.md에 결과 보고서를 작성하세요."}'
