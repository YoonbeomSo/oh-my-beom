#!/usr/bin/env bash
# TaskCompleted hook for oh-my-beom plugin
# 태스크 완료 시 계획 파일의 완료 기준을 검증하여 품질 게이트 역할을 수행한다.
# exit 0: 완료 허용, exit 2: 완료 차단 + stderr 피드백

set -euo pipefail

INPUT=$(cat /dev/stdin 2>/dev/null || echo '{}')
CWD=$(echo "$INPUT" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    print(data.get('cwd', '.'))
except:
    print('.')
" 2>/dev/null || echo ".")

# config.json에서 verification 설정 확인
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(dirname "$0")/..}"
CONFIG_FILE="${PLUGIN_ROOT}/config/config.json"

VERIFICATION_ENABLED=$(python3 -c "
import json, sys
try:
    with open('${CONFIG_FILE}') as f:
        config = json.load(f)
    print('true' if config.get('verification', {}).get('enabled', True) else 'false')
except:
    print('true')
" 2>/dev/null || echo "true")

if [ "$VERIFICATION_ENABLED" = "false" ]; then
  exit 0
fi

# docs/plan/ 에서 IN_PROGRESS 상태인 계획 파일 탐색
PLAN_DIR="${CWD}/docs/plan"
if [ ! -d "$PLAN_DIR" ]; then
  exit 0
fi

ACTIVE_PLAN=$(python3 << 'PYEOF'
import glob, re, sys

plan_dir = sys.argv[1] if len(sys.argv) > 1 else "docs/plan"
plans = glob.glob(f"{plan_dir}/*-plan.md")

for plan in plans:
    try:
        with open(plan) as f:
            content = f.read()
        if re.search(r'상태:\s*IN_PROGRESS', content):
            print(plan)
            sys.exit(0)
    except:
        continue

sys.exit(0)
PYEOF
"$PLAN_DIR" 2>/dev/null || echo "")

if [ -z "$ACTIVE_PLAN" ]; then
  exit 0
fi

# 계획 파일 파싱 및 검증
RESULT=$(python3 << 'PYEOF'
import json, re, subprocess, sys, os

plan_path = sys.argv[1]
config_path = sys.argv[2]
cwd = sys.argv[3]

# config 로드
try:
    with open(config_path) as f:
        config = json.load(f)
except:
    config = {}

project_types = config.get("projectTypes", {})
mechanical = config.get("verification", {}).get("mechanicalChecks", {})

# 프로젝트 타입 감지
detected_type = None
for ptype, pconfig in project_types.items():
    for detect_file in pconfig.get("detect", []):
        if os.path.exists(os.path.join(cwd, detect_file)):
            detected_type = ptype
            break
    if detected_type:
        break

# 계획 파일 파싱
with open(plan_path) as f:
    content = f.read()

failures = []

# 미완료 TODO 항목 수집
unchecked_todos = re.findall(r'- \[ \] \[TODO-[\d.]+\]\s*(.+)', content)
for todo in unchecked_todos:
    failures.append(f"[TODO] 미완료: {todo.strip()}")

# FAILED 상태 항목 수집
failed_items = re.findall(r'검증 상태:\s*FAILED', content)
if failed_items:
    failures.append(f"[VERIFICATION] 검증 실패 항목 {len(failed_items)}건")

# 최종 완료 기준 중 미체크 항목
final_criteria = re.findall(r'- \[ \] \[(LINT|TEST|BUILD|FILE_EXISTS|GREP_MATCH|CRITERIA)\]\s*(.+)', content)
for tag, desc in final_criteria:
    if tag == "LINT" and mechanical.get("lint", True) and detected_type:
        lint_cmd = project_types.get(detected_type, {}).get("lint", "")
        if lint_cmd:
            failures.append(f"[LINT] 린트 미통과 (명령: {lint_cmd.split('|')[0].strip()})")
    elif tag == "TEST" and mechanical.get("test", True) and detected_type:
        failures.append("[TEST] 테스트 미통과")
    elif tag == "BUILD" and mechanical.get("build", True) and detected_type:
        failures.append("[BUILD] 빌드 미통과")
    elif tag == "FILE_EXISTS":
        path = desc.strip()
        if not os.path.exists(os.path.join(cwd, path)):
            failures.append(f"[FILE_EXISTS] 파일 없음: {path}")
    elif tag == "CRITERIA":
        failures.append(f"[CRITERIA] 미검증 (에이전트 확인 필요): {desc.strip()}")

if not failures:
    print("PASS")
else:
    output = ["[QUALITY GATE] 완료 기준 미충족으로 작업 완료를 차단합니다.", "", "미충족 항목:"]
    for f in failures:
        output.append(f"- {f}")
    output.append("")
    output.append("다음 조치:")
    output.append("1. 미완료 TODO 항목을 구현하세요.")
    output.append("2. [CRITERIA] 항목은 todo-verifier 에이전트로 검증하세요.")
    output.append(f"3. 계획 파일: {plan_path}")
    print("\n".join(output))
PYEOF
"$ACTIVE_PLAN" "$CONFIG_FILE" "$CWD" 2>/dev/null || echo "PASS")

if [ "$RESULT" = "PASS" ]; then
  exit 0
else
  echo "$RESULT" >&2
  exit 2
fi
