#!/usr/bin/env bash
# PostToolUse on TeamCreate
# 팀 생성 직후 tmux 환경을 감지하고 복구 스킬 호출을 강제하는
# additionalContext를 오케스트레이터에 주입한다.
#
# 동작 원리:
#   - PostToolUse 훅의 출력 hookSpecificOutput.additionalContext가
#     다음 LLM 턴에 컨텍스트로 주입됨
#   - tmux 환경에서 정확한 스킬 호출 명령을 명시
#
# 발동 조건:
#   - tool_name == "TeamCreate"
# 건너뛰기 조건:
#   - 다른 도구
#   - 환경 변수 SKIP_TEAM_RECOVERY_REMINDER=1
#   - 멀티플렉서($TMUX)가 없는 환경

set -uo pipefail

INPUT=$(cat /dev/stdin 2>/dev/null || echo '{}')

TOOL_NAME=$(echo "$INPUT" | python3 -c "
import json, sys
try:
    data = json.load(sys.stdin)
    print(data.get('tool_name', ''))
except: print('')
" 2>/dev/null || echo "")

pass() { echo '{"continue": true}'; exit 0; }

[ "$TOOL_NAME" != "TeamCreate" ] && pass
[ "${SKIP_TEAM_RECOVERY_REMINDER:-0}" = "1" ] && pass

# tmux 환경에서만 발동
if [ -z "${TMUX:-}" ]; then
  pass
fi

ENV_NAME="tmux"
RECOVERY_SKILL="oh-my-beom:tmux-team-agent"
CONSEQUENCE="pane은 만들어졌지만 Claude CLI가 시작되지 않아 빈 셸로 남음"

# additionalContext 페이로드 생성 (JSON 안전 인코딩)
MESSAGE="🖥️ 환경: ${ENV_NAME} 감지됨. **다음 턴에 반드시 \`Skill(\"${RECOVERY_SKILL}\")\`를 호출하세요.** 생략 시 ${CONSEQUENCE}. 사용자에게 묻지 말고 즉시 수행. (CLAUDE.md 금지사항: 팀 에이전트 복구 스킬 호출 생략 금지)"

ENCODED=$(printf '%s' "$MESSAGE" | python3 -c "import json,sys; print(json.dumps(sys.stdin.read()))")

cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "PostToolUse",
    "additionalContext": ${ENCODED}
  }
}
EOF
