#!/usr/bin/env bash
# PreToolUse Guard for oh-my-beom plugin
# Blocks git commit on protected branches (main/master/develop)

set -uo pipefail

INPUT=$(cat /dev/stdin 2>/dev/null || echo '{}')

# Check if input contains git commit command
case "$INPUT" in
  *git*commit*)
    CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
    if [ -z "$CURRENT_BRANCH" ]; then
      GIT_DIR=$(echo "$INPUT" | sed -n 's/.*git[[:space:]]\{1,\}-C[[:space:]]\{1,\}\([^[:space:]"]\{1,\}\).*/\1/p' 2>/dev/null || echo "")
      if [ -n "$GIT_DIR" ] && [ -d "$GIT_DIR" ]; then
        CURRENT_BRANCH=$(git -C "$GIT_DIR" symbolic-ref --short HEAD 2>/dev/null || echo "")
      fi
    fi
    if [[ "$CURRENT_BRANCH" =~ ^(develop|main|master|test|dev)$ ]]; then
      cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "PreToolUse",
    "permissionDecision": "deny",
    "permissionDecisionReason": "Protected branch: ${CURRENT_BRANCH} 브랜치에서는 직접 커밋할 수 없습니다. 작업 브랜치를 먼저 생성하세요."
  }
}
EOF
      exit 0
    fi
    ;;
esac

echo '{"continue": true}'
exit 0
