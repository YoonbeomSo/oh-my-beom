#!/usr/bin/env bash
# PreToolUse Guard for oh-my-beom plugin
# 1. 보호 브랜치 커밋 차단
# 2. 보호 브랜치 push 차단 (force push 포함)
# 3. config/config.json 개인정보 커밋 차단

set -uo pipefail

INPUT=$(cat /dev/stdin 2>/dev/null || echo '{}')

# ─── tool_input.command에서 git 명령만 추출 ───
# echo "git push ..." 등 문자열 내부의 git 명령은 무시하고,
# 실제 실행되는 git 명령(첫 단어가 git인 서브커맨드)만 추출한다.
CMD=$(echo "$INPUT" | python3 -c "
import json, sys, re
try:
    data = json.load(sys.stdin)
    full_cmd = data.get('tool_input', {}).get('command', '')
    # &&, ;, | 로 분리된 서브커맨드 중 'git '으로 시작하는 것만 추출
    parts = re.split(r'[;&|]+', full_cmd)
    git_cmds = [p.strip() for p in parts if re.match(r'\s*git\s', p.strip())]
    # 모든 git 명령을 줄바꿈으로 연결하여 반환 (각각 검사 대상)
    print('\n'.join(git_cmds) if git_cmds else '')
except:
    print('')
" 2>/dev/null || echo "")

# ─── 위험 시스템 명령 차단 (git 이외) ───
FULL_CMD=$(echo "$INPUT" | python3 -c "
import json, sys
try:
    data = json.load(sys.stdin)
    print(data.get('tool_input', {}).get('command', ''))
except: print('')
" 2>/dev/null || echo "")

deny() {
  local reason="$1"
  cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "PreToolUse",
    "permissionDecision": "deny",
    "permissionDecisionReason": "${reason}"
  }
}
EOF
  exit 0
}

# rm -rf / 또는 ~ 차단
if echo "$FULL_CMD" | grep -qE 'rm\s+(-rf|-fr)\s+(/|~|\$HOME)' 2>/dev/null; then
  deny "위험 명령: rm -rf로 루트/홈 디렉토리 삭제 시도 감지"
fi

# chmod 777 차단
if echo "$FULL_CMD" | grep -qE 'chmod\s+777' 2>/dev/null; then
  deny "위험 명령: chmod 777은 보안상 금지"
fi

# git 명령이 아니면 통과
if [ -z "$CMD" ]; then
  echo '{"continue": true}'
  exit 0
fi

get_branch() {
  local branch
  branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
  if [ -z "$branch" ]; then
    local git_dir
    git_dir=$(echo "$CMD" | sed -n 's/.*git[[:space:]]\{1,\}-C[[:space:]]\{1,\}\([^[:space:]"]\{1,\}\).*/\1/p' 2>/dev/null || echo "")
    if [ -n "$git_dir" ] && [ -d "$git_dir" ]; then
      branch=$(git -C "$git_dir" symbolic-ref --short HEAD 2>/dev/null || echo "")
    fi
  fi
  echo "$branch"
}

PROTECTED_RE="^(develop|main|master|test|dev)$"

# CMD는 줄바꿈으로 구분된 여러 git 명령일 수 있음 (체인 명령)
# 각 git 명령을 개별 검사한다
while IFS= read -r GIT_CMD; do
  [ -z "$GIT_CMD" ] && continue

  case "$GIT_CMD" in
    # ─── git push 보호 ───
    git\ push*)
      # force push 차단
      case "$GIT_CMD" in
        *--force*|*" -f "*)
          deny "git push --force는 금지되어 있습니다."
          ;;
      esac

      # 보호 브랜치로의 직접 push 차단
      for b in main master develop test dev; do
        case "$GIT_CMD" in
          *"origin ${b}"*|*"origin/${b}"*|*":${b}"*|*"HEAD:${b}"*)
            deny "Protected branch: ${b} 브랜치로 직접 push할 수 없습니다."
            ;;
        esac
      done

      # 현재 보호 브랜치에서 타겟 미지정 bare push 차단
      CURRENT=$(get_branch)
      if [[ -n "$CURRENT" && "$CURRENT" =~ $PROTECTED_RE ]]; then
        if echo "$GIT_CMD" | grep -qE 'origin[[:space:]]+[a-zA-Z]' 2>/dev/null; then
          :
        else
          deny "Protected branch: ${CURRENT} 브랜치에서 직접 push할 수 없습니다. 작업 브랜치로 전환하세요."
        fi
      fi
      ;;

    # ─── git commit 보호 ───
    git\ commit*)
      # 보호 브랜치 커밋 차단
      CURRENT=$(get_branch)
      if [[ -n "$CURRENT" && "$CURRENT" =~ $PROTECTED_RE ]]; then
        deny "Protected branch: ${CURRENT} 브랜치에서는 직접 커밋할 수 없습니다. 작업 브랜치를 먼저 생성하세요."
      fi

      # config/config.json 개인정보 커밋 차단
      if git diff --cached --name-only 2>/dev/null | grep -q "config/config.json"; then
        HAS_CREDS=$(git show :config/config.json 2>/dev/null | python3 -c "
import json, sys
try:
    data = json.load(sys.stdin)
    creds = data.get('webTest', {}).get('credentials', {})
    if creds and any(v for v in creds.values() if isinstance(v, dict) and (v.get('id') or v.get('pw') or v.get('password'))):
        print('yes')
    else:
        print('no')
except:
    print('no')
" 2>/dev/null || echo "no")
        if [ "$HAS_CREDS" = "yes" ]; then
          deny "config/config.json에 개인정보(webTest.credentials)가 포함되어 있습니다. credentials를 비운 후 다시 커밋하세요."
        fi
      fi

      # [WEB-TEST-REQUIRED] 웹 테스트 미실행 차단
      if [ -f ".dev/web-test-required" ] && [ ! -f ".dev/web-test-passed" ]; then
        deny "[WEB-TEST-REQUIRED] qa-manager가 웹 테스트를 요구했지만 아직 실행되지 않았습니다. web-test 스킬을 먼저 실행하세요."
      fi
      ;;
  esac
done <<< "$CMD"

echo '{"continue": true}'
exit 0
