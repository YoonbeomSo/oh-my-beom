{
  "protectedBranches": ["main", "master", "develop", "test", "dev"],
  "protectedPluginPaths": ["hooks/", "rules/", "config/", "agents/", "skills/", ".claude-plugin/", "CLAUDE.md"],
  "issueKey": {
    "pattern": "^[A-Z]+-[0-9]+$",
    "description": "대문자 영문 1자 이상 + '-' + 숫자 1자 이상 (e.g., JIRA-123, AFS-6)"
  },
  "sensitiveFilePatterns": [
    ".env*",
    "*.key",
    "*.pem",
    "credentials*",
    "*secret*",
    "*.p12",
    "*.jks"
  ],
  "buildArtifactPatterns": [
    "build/",
    ".gradle/",
    "node_modules/",
    "dist/",
    "__pycache__/",
    ".venv/",
    "target/",
    ".next/",
    "out/"
  ],
  "projectTypes": {
    "kotlin-java": {
      "detect": ["build.gradle.kts", "build.gradle"],
      "build": "./gradlew build",
      "lint": "./gradlew ktlintFormat",
      "test": "./gradlew test"
    },
    "nodejs": {
      "detect": ["package.json"],
      "build": "npm run build | bun run build",
      "lint": "npm run lint -- --fix | bun run lint --fix",
      "test": "npm test | bun test",
      "runtimeDetect": "which bun -> bun, otherwise npm"
    },
    "python": {
      "detect": ["pyproject.toml", "setup.py"],
      "build": "python -m build",
      "lint": "ruff format . && ruff check --fix .",
      "test": "pytest --tb=short"
    }
  },
  "timeouts": {
    "lint": 300000,
    "test": 300000,
    "build": 300000,
    "network": 120000,
    "install": 300000
  },
  "contextLimits": {
    "planner": { "maxInputLines": 800, "note": "요구사항 + 코드 맵" },
    "architect": { "maxInputLines": 1500, "note": "plan + 코드 맵 + 컨벤션" },
    "coder": { "maxInputLines": 2000, "note": "설계서 + 코드 맵 + 참조 코드" },
    "reviewer": { "maxInputLines": 1500, "note": "diff + plan 완료 기준 + 코드 맵" }
  },
  "webTest": {
    "triggerConditions": [
      "프론트엔드 프로젝트 (React, Vue, Next.js, Nuxt 등)",
      "어드민/백오피스 프로젝트",
      "변경 범위에 프론트엔드 코드 포함 (*.tsx, *.vue, *.html 등)"
    ],
    "detectPatterns": {
      "frontend": ["src/pages/**", "src/views/**", "src/components/**", "app/**/*.tsx", "pages/**/*.vue"],
      "admin": ["**/admin/**", "**/backoffice/**", "**/back-office/**", "**/management/**"]
    },
    "credentials": {}
  },
  "verification": {
    "enabled": true,
    "planDirectory": "docs/plan",
    "mechanicalChecks": {
      "lint": true,
      "test": true,
      "build": true
    }
  }
}
